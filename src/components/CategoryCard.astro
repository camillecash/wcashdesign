---
import type {Category} from '../data/site'
import {assetPath} from '../utils/paths'

type Props = {
  category: Category
  index?: number
  isPreview?: boolean
}

const {category, index = 0, isPreview = false} = Astro.props
const href = `${isPreview ? '/preview' : ''}/portfolio/${category.slug}/`
---
<a class={`category-card category-${category.slug}`} href={href} data-reveal style={`--delay:${index * 18}ms`}>
  <div class="category-image">
    <img src={assetPath(category.previewImage)} alt={category.title} loading={index > 2 ? 'lazy' : 'eager'} />
    <span>View more</span>
  </div>
  <div class="category-copy">
    <p>{category.shortTitle}</p>
    <h3>{category.title}</h3>
    <span>{category.description}</span>
  </div>
</a>
