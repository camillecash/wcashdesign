---
import BaseLayout from '../layouts/BaseLayout.astro'
import PortfolioPage from '../components/pages/PortfolioPage.astro'
import {getCategories, getPortfolioPage} from '../data/sanity'

const categories = await getCategories()
const portfolioPage = await getPortfolioPage()
---
<BaseLayout title="Portfolio" description={portfolioPage.intro} current="portfolio">
  <PortfolioPage categories={categories} portfolioPage={portfolioPage} />
</BaseLayout>
