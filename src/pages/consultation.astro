---
import BaseLayout from '../layouts/BaseLayout.astro'
import ConsultationPage from '../components/pages/ConsultationPage.astro'
import {getConsultationPage, getSiteSettings} from '../data/sanity'

const consultationPage = await getConsultationPage()
const siteSettings = await getSiteSettings()
---
<BaseLayout title="Consultation" description={consultationPage.intro} current="consultation">
  <ConsultationPage consultationPage={consultationPage} siteSettings={siteSettings} />
</BaseLayout>
