---
import BaseLayout from '../layouts/BaseLayout.astro'
import CategoryCard from '../components/CategoryCard.astro'
import ConsultationForm from '../components/ConsultationForm.astro'
import {siteSettings as fallbackSiteSettings, type GalleryImage} from '../data/site'
import {getCategories, getConsultationPage, getHomePage, getSiteSettings} from '../data/sanity'
import {assetPath} from '../utils/paths'

const categories = await getCategories()
const homePage = await getHomePage()
const siteSettings = await getSiteSettings()
const consultationPage = await getConsultationPage()

const findCategory = (slug: string) => categories.find((category) => category.slug === slug)
const fallbackFeatureImages = [
  findCategory('restorations')?.images[0],
  findCategory('professional-headshots')?.images[0],
  findCategory('flyers-posters')?.images[0],
  findCategory('creations-and-edits')?.images[8],
].filter(Boolean) as GalleryImage[]
const featureImages = homePage.featuredImages?.length ? homePage.featuredImages : fallbackFeatureImages

const marqueeLinks = homePage.marqueeItems
const portfolioTitleLines = homePage.portfolioTitle.split('\n').filter(Boolean)
---
<BaseLayout title={siteSettings.title || fallbackSiteSettings.title} current="home">
  <main>
    <section class="hero">
      <div class="hero-copy" data-reveal>
        <p class="kicker">{homePage.heroKicker}</p>
        <h1>{homePage.heroTitle}</h1>
        <p>{homePage.heroText}</p>
        <div class="action-row">
          <a class="button" href={homePage.primaryActionLink}>{homePage.primaryAction}</a>
          <a class="button ghost" href={homePage.secondaryActionLink}>{homePage.secondaryAction}</a>
        </div>
      </div>
      <div class="hero-gallery" aria-label="Featured WCashDesign work">
        {featureImages.map((image, index) => (
          <img src={assetPath(image.src)} alt={image.alt} style={`--i:${index}`} />
        ))}
      </div>
    </section>

    <section class="logo-marquee" aria-label="Services">
      <div>
        {[...marqueeLinks, ...marqueeLinks, ...marqueeLinks].map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
    </section>

    <section class="section about-grid">
      <div class="about-image" data-reveal>
        <img src={assetPath(homePage.aboutImage)} alt={homePage.aboutImageAlt || 'Walter Cash'} />
      </div>
      <div data-reveal="side">
        <p class="kicker">{homePage.aboutKicker}</p>
        <h2>{homePage.aboutTitle}</h2>
        <p>{homePage.aboutText}</p>
        <p class="contact-label">{homePage.contactLabel}</p>
        <div class="contact-pills">
          <a href={siteSettings.phoneHref}>
            <svg class="contact-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M6.6 10.8c1.5 3 3.6 5.1 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.7 0 1.2.5 1.2 1.2v3.5c0 .7-.5 1.2-1.2 1.2C10.1 21.4 2.6 13.9 2.6 3.4c0-.7.5-1.2 1.2-1.2h3.5c.7 0 1.2.5 1.2 1.2 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-2.2 2.2z" />
            </svg>
            {siteSettings.phoneDisplay}
          </a>
          <a href={`mailto:${siteSettings.email}`}>
            <svg class="contact-icon" aria-hidden="true" viewBox="0 0 24 24">
              <path d="M3.5 5.5h17c.8 0 1.5.7 1.5 1.5v10c0 .8-.7 1.5-1.5 1.5h-17c-.8 0-1.5-.7-1.5-1.5V7c0-.8.7-1.5 1.5-1.5zm.7 2.6 7.1 5.1c.4.3.9.3 1.3 0l7.1-5.1" />
            </svg>
            {siteSettings.email}
          </a>
          <a href={siteSettings.instagram} target="_blank" rel="noreferrer">
            <svg class="contact-icon" aria-hidden="true" viewBox="0 0 24 24">
              <rect x="3" y="3" width="18" height="18" rx="5" />
              <circle cx="12" cy="12" r="4" />
              <circle cx="17.3" cy="6.7" r="1.1" />
            </svg>
            Instagram
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="section-heading portfolio-heading" data-reveal>
        <p class="kicker">{homePage.portfolioKicker}</p>
        <h2>
          {portfolioTitleLines.map((line, index) => (
            <>
              {index > 0 && <br />}
              {line}
            </>
          ))}
        </h2>
        <a class="text-link" href="/portfolio/">{homePage.portfolioLinkLabel}</a>
      </div>
      <div class="category-grid">
        {categories.map((category, index) => <CategoryCard category={category} index={index} />)}
      </div>
    </section>

    <section class="section consultation-band" id="consultation">
      <div data-reveal>
        <p class="kicker">{homePage.consultationKicker}</p>
        <h2>{homePage.consultationTitle}</h2>
        <p>{homePage.consultationText}</p>
      </div>
      <ConsultationForm form={consultationPage} endpoint={consultationPage.formspreeEndpoint || siteSettings.formspreeEndpoint} />
    </section>
  </main>
</BaseLayout>
